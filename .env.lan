# LAN MODE ONLY — loaded when you run `npm run dev:lan` (Vite's --mode lan).
# Your regular `npm run dev` still uses plain .env (VITE_API_BASE_URL=localhost)
# and is completely unaffected by this file — that's the easy revert path,
# there's nothing to undo there.
#
# 192.168.29.212 is this machine's LAN IP at time of setup. If it changes
# (e.g. reconnecting to Wi-Fi), run `ipconfig getifaddr en0` and update it here,
# and in the backend's .env ALLOWED_ORIGINS.
VITE_API_BASE_URL="http://192.168.29.212:8000"
