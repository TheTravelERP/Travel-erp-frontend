# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env files — no secrets currently live here, but keep local/LAN config
# out of a public repo as a matter of hygiene. Copy .env.example to .env locally.
.env
.env.*
!.env.example

# Personal/confidential working files — never commit these.
# Covers a folder named important/confidential, or any file named
# important.* / confidential.* (any extension).
important/
important.*
confidential/
confidential.*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
